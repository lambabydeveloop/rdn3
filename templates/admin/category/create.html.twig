{% extends 'admin/dashboard.html.twig' %}

{% block title %}Редактировать категорию - RDN Admin{% endblock %}

{% block dashboard_content %}
    <header class="px-8 py-6 flex flex-col md:flex-row md:items-center justify-between gap-6 shrink-0 z-10 border-b border-black/5 dark:border-white/5">
        <div class="flex items-center gap-4">
            <a href="{{ path('app_admin_category_index') }}" class="w-10 h-10 flex items-center justify-center rounded-xl bg-black/5 dark:bg-white/5 hover:bg-black/10 dark:hover:bg-white/10 text-gray-500 dark:text-gray-400 transition-colors">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            </a>
            <div>
                <h1 class="text-2xl font-bold text-black dark:text-white tracking-tight">{{ category.id ? 'Редактировать' : 'Новая категория' }}</h1>
                <p class="text-gray-500 text-sm">Управление рубрикой блога.</p>
            </div>
        </div>
    </header>

    <div class="flex-1 overflow-y-auto w-full p-8 flex justify-center">
        
        <form method="post" class="w-full max-w-2xl bg-white dark:bg-[#1a1a1a] rounded-3xl p-8 border border-black/5 dark:border-white/5 shadow-sm flex flex-col gap-6">
            
            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Название категории</label>
                <input type="text" name="name" value="{{ category.name }}" required class="w-full bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">URL Slug (оставьте пустым для авто-генерации)</label>
                <input type="text" name="slug" value="{{ category.slug }}" class="w-full bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-indigo-500 transition-colors" placeholder="my-category">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Цвет (основной цвет рубрики)</label>
                <input type="color" name="color" value="{{ category.color|default('#6366f1') }}" class="w-16 h-12 bg-transparent border border-black/10 dark:border-white/10 rounded-xl cursor-pointer">
            </div>

            <div class="mt-8 pt-6 border-t border-black/5 dark:border-white/5 flex justify-end">
                <button type="submit" class="bg-indigo-500 hover:bg-indigo-600 text-white font-bold py-3 px-8 rounded-xl transition-colors">Сохранить</button>
            </div>
            
        </form>

    </div>
{% endblock %}
