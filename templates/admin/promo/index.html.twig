{% extends 'admin/dashboard.html.twig' %}

{% block title %}Промо акции - RDN Admin{% endblock %}

{% block dashboard_content %}
    <header class="px-8 py-6 flex flex-col md:flex-row md:items-center justify-between gap-6 shrink-0 z-10">
        <div class="greeting-anim">
            <h1 class="text-3xl font-light text-black dark:text-white tracking-tight">Рекламные промо</h1>
            <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">Управление баннерами и офферами в блоге.</p>
        </div>
        
        <div class="flex items-center gap-4 greeting-anim" style="--stagger: 2;">
            <a href="{{ path('app_admin_promo_create') }}" class="bg-black dark:bg-white text-white dark:text-black font-semibold py-2 px-6 rounded-xl hover:scale-105 transition-transform flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Добавить промо
            </a>
        </div>
    </header>

    <div class="flex-1 overflow-y-auto custom-scrollbar px-8 pb-8 z-10 flex flex-col gap-8">
        
        <div class="bg-white/80 dark:bg-[#1a1a1a]/80 backdrop-blur-md rounded-3xl p-6 border border-black/5 dark:border-white/5 shadow-sm dashboard-card" style="--stagger: 3;">
            <h2 class="text-xl font-bold text-black dark:text-white mb-6">Все промо акции</h2>
            {% if promos|length > 0 %}
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="text-gray-400 dark:text-gray-500 text-sm border-b border-black/5 dark:border-white/5">
                                <th class="pb-3 font-medium px-4">Заголовок</th>
                                <th class="pb-3 font-medium px-4">Лейбл</th>
                                <th class="pb-3 font-medium px-4 border-l border-black/5 dark:border-white/5">Статус</th>
                                <th class="pb-3 font-medium px-4 text-right">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in promos %}
                                <tr class="hover:bg-black/[0.02] dark:hover:bg-white/[0.02] transition-colors border-b border-black/5 dark:border-white/5 last:border-0">
                                    <td class="py-4 px-4 font-medium text-black dark:text-white">{{ item.title }}</td>
                                    <td class="py-4 px-4 text-gray-500 text-sm"><span class="px-2 py-1 rounded bg-black/5 dark:bg-white/5">{{ item.label }}</span></td>
                                    <td class="py-4 px-4 text-sm">{{ item.isActive ? '<span class="text-green-500 font-bold">Активно</span>' : '<span class="text-red-500 font-bold">Выключено</span>'|raw }}</td>
                                    <td class="py-4 px-4 text-right">
                                        <a href="{{ path('app_admin_promo_edit', {id: item.id}) }}" class="text-indigo-500 hover:text-indigo-600 font-medium text-sm">Изменить</a>
                                        <form method="post" action="{{ path('app_admin_promo_delete', {id: item.id}) }}" class="inline-block ml-3" onsubmit="return confirm('Удалить промо?');">
                                            <button type="submit" class="text-red-500 hover:text-red-600 font-medium text-sm">Удалить</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-gray-500 italic text-sm py-4">Вы еще не создавали промо акции.</p>
            {% endif %}
        </div>
    </div>
{% endblock %}
