{% extends 'admin/base.html.twig' %}

{% block title %}Дашборд - RDN Admin{% endblock %}

{% block body %}
<div class="h-screen w-full flex overflow-hidden relative">

    <!-- Mobile Header & Hamburger (Visible only on mobile) -->
    <div class="lg:hidden absolute top-0 left-0 w-full h-16 bg-white/50 dark:bg-black/50 backdrop-blur-md border-b border-black/5 dark:border-white/5 z-40 flex items-center justify-between px-6 dashboard-mobile-nav">
        <div class="font-bold text-xl tracking-widest uppercase">RDN</div>
        <button id="mobile-menu-btn" class="w-10 h-10 flex flex-col justify-center items-center gap-1.5 z-50 rounded-full bg-black/5 dark:bg-white/5 relative">
            <span class="w-5 h-[2px] bg-black dark:bg-white transition-transform block"></span>
            <span class="w-5 h-[2px] bg-black dark:bg-white transition-opacity block"></span>
            <span class="w-5 h-[2px] bg-black dark:bg-white transition-transform block"></span>
        </button>
    </div>

    <!-- Overlay for mobile sidebar -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/20 dark:bg-black/60 backdrop-blur-sm z-30 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"></div>

    <!-- Sidebar Wrapper -->
    <div id="sidebar" class="fixed lg:relative inset-y-0 left-0 z-40 flex h-full transform -translate-x-full lg:translate-x-0 transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] sidebar-closed">
        
        <!-- Sidebar 1: Thin Icon Bar (Dark Capsule) -->
        <div class="w-[72px] pl-3 py-3 flex-shrink-0 flex items-center sidebar-item" style="--stagger: 1;">
            <div class="w-full h-full bg-[#111] dark:bg-[#0a0a0a] rounded-full flex flex-col items-center py-6 gap-6 border border-white/10 shadow-2xl z-20">
                <!-- Logo Mark -->
                <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-xl bg-white/10 mb-2 cursor-pointer hover:bg-white/20 transition-colors">
                    R
                </div>
                
                <!-- Nav Icons -->
                <nav class="flex flex-col gap-5 w-full items-center flex-1">
                    <a href="{{ path('app_admin_dashboard') }}" class="w-10 h-10 rounded-full {% if app.request.get('_route') == 'app_admin_dashboard' %}bg-white/20 text-white shadow-[0_0_15px_rgba(255,255,255,0.2)]{% else %}text-white/40 hover:text-white hover:bg-white/10{% endif %} flex items-center justify-center transition-all">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                    </a>
                    <a href="{{ path('app_admin_blog_index') }}" class="w-10 h-10 rounded-full {% if 'blog' in app.request.get('_route') %}bg-white/20 text-white shadow-[0_0_15px_rgba(255,255,255,0.2)]{% else %}text-white/40 hover:text-white hover:bg-white/10{% endif %} flex items-center justify-center transition-all group">
                        <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
                    </a>
                    <a href="#" class="w-10 h-10 rounded-full text-white/40 hover:text-white hover:bg-white/10 flex items-center justify-center transition-all group">
                        <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                    </a>
                    <a href="#" class="w-10 h-10 rounded-full text-white/40 hover:text-white hover:bg-white/10 flex items-center justify-center transition-all group">
                        <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg>
                    </a>
                </nav>

                <!-- Bottom Settings -->
                <a href="{{ path('app_admin_logout') }}" class="w-10 h-10 rounded-full text-white/40 hover:text-red-400 hover:bg-white/10 flex items-center justify-center transition-all mt-auto group" title="Выйти">
                    <svg class="w-5 h-5 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                </a>
                <a href="#" class="w-10 h-10 rounded-full text-white/40 hover:text-white hover:bg-white/10 flex items-center justify-center transition-all group" title="Настройки">
                    <svg class="w-5 h-5 group-hover:rotate-90 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </a>
            </div>
        </div>

        <!-- Sidebar 2: Secondary Menu -->
        <div class="w-72 pl-3 py-3 pr-0 flex-shrink-0 sidebar-item" style="--stagger: 2;">
            <div class="w-full h-full bg-white/70 dark:bg-[#151515]/70 backdrop-blur-3xl rounded-[32px] border border-white dark:border-white/5 shadow-sm flex flex-col pt-8 pb-6 custom-scrollbar overflow-y-auto z-10 relative">
                
                <!-- Close Button (Mobile Only) -->
                <button id="mobile-close-btn" class="lg:hidden absolute top-6 right-6 w-8 h-8 flex items-center justify-center rounded-full bg-black/5 dark:bg-white/5 text-gray-500 hover:text-black dark:hover:text-white transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>

                <!-- User Profile Block -->
                <div class="px-6 flex items-center gap-4 mb-8">
                    <div class="w-12 h-12 rounded-full overflow-hidden border border-black/10 dark:border-white/10 shrink-0">
                        <img src="https://ui-avatars.com/api/?name=Admin+RDN&background=random" alt="Admin" class="w-full h-full object-cover">
                    </div>
                    <div class="overflow-hidden">
                        <h3 class="font-bold text-[15px] truncate text-black dark:text-white">Admin RDN</h3>
                        <p class="text-[12px] text-gray-500 dark:text-gray-400 truncate">{{ app.user.email|default('info@rdn.by') }}</p>
                    </div>
                </div>

                <div class="px-6 mb-8">
                    <h4 class="text-[11px] uppercase tracking-widest text-gray-400 mb-3 font-semibold">Проекты</h4>
                    <div class="space-y-1">
                        <a href="{{ path('app_admin_dashboard') }}" class="flex items-center justify-between px-4 py-2.5 {% if app.request.get('_route') == 'app_admin_dashboard' %}bg-white dark:bg-black/40 rounded-xl shadow-[0_2px_10px_rgba(0,0,0,0.03)] dark:border dark:border-white/5 border border-black/5 text-black dark:text-white transition-transform hover:scale-[1.02]{% else %}text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors rounded-xl hover:bg-black/5 dark:hover:bg-white/5{% endif %}">
                            <div class="flex items-center gap-3">
                                <svg class="w-4 h-4 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                                <span class="font-medium text-[14px]">Дашборд</span>
                            </div>
                            <span class="w-6 h-6 rounded-full bg-gray-100 dark:bg-white/10 flex items-center justify-center text-[11px] font-bold">0</span>
                        </a>
                        <a href="{{ path('app_admin_blog_index') }}" class="flex items-center justify-between px-4 py-2.5 {% if 'blog' in app.request.get('_route') %}bg-white dark:bg-black/40 rounded-xl shadow-[0_2px_10px_rgba(0,0,0,0.03)] dark:border dark:border-white/5 border border-black/5 text-black dark:text-white transition-transform hover:scale-[1.02]{% else %}text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors rounded-xl hover:bg-black/5 dark:hover:bg-white/5{% endif %}">
                            <div class="flex items-center gap-3">
                                <svg class="w-4 h-4 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
                                <span class="font-medium text-[14px]">Блог</span>
                            </div>
                        </a>
                        <a href="{{ path('app_admin_category_index') }}" class="flex items-center justify-between px-4 py-2.5 {% if 'category' in app.request.get('_route') %}bg-white dark:bg-black/40 rounded-xl shadow-[0_2px_10px_rgba(0,0,0,0.03)] dark:border dark:border-white/5 border border-black/5 text-black dark:text-white transition-transform hover:scale-[1.02]{% else %}text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors rounded-xl hover:bg-black/5 dark:hover:bg-white/5{% endif %}">
                            <div class="flex items-center gap-3">
                                <svg class="w-4 h-4 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                                <span class="font-medium text-[14px]">Категории</span>
                            </div>
                        </a>
                        <a href="{{ path('app_admin_promo_index') }}" class="flex items-center justify-between px-4 py-2.5 {% if 'promo' in app.request.get('_route') %}bg-white dark:bg-black/40 rounded-xl shadow-[0_2px_10px_rgba(0,0,0,0.03)] dark:border dark:border-white/5 border border-black/5 text-black dark:text-white transition-transform hover:scale-[1.02]{% else %}text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors rounded-xl hover:bg-black/5 dark:hover:bg-white/5{% endif %}">
                            <div class="flex items-center gap-3">
                                <svg class="w-4 h-4 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
                                <span class="font-medium text-[14px]">Промо акции</span>
                            </div>
                        </a>
                    </div>
                </div>

                <div class="px-6 mb-8">
                    <h4 class="text-[11px] uppercase tracking-widest text-gray-400 mb-3 font-semibold">Статус</h4>
                    <div class="space-y-1">
                        <div class="flex items-center justify-between px-4 py-2.5 group cursor-pointer rounded-xl hover:bg-black/5 dark:hover:bg-white/5 transition-colors">
                            <div class="flex items-center gap-3 text-gray-600 dark:text-gray-300 group-hover:text-black dark:group-hover:text-white">
                                <span class="w-2 h-2 rounded-full border-2 border-black dark:border-white"></span>
                                <span class="font-medium text-[14px]">Новые</span>
                            </div>
                            <span class="text-[12px] text-gray-400">3</span>
                        </div>
                        <div class="flex items-center justify-between px-4 py-2.5 group cursor-pointer rounded-xl hover:bg-black/5 dark:hover:bg-white/5 transition-colors">
                            <div class="flex items-center gap-3 text-gray-600 dark:text-gray-300 group-hover:text-black dark:group-hover:text-white">
                                <span class="w-2 h-2 rounded-full bg-black dark:bg-white"></span>
                                <span class="font-medium text-[14px]">Обновления</span>
                            </div>
                            <span class="text-[12px] text-gray-400">2</span>
                        </div>
                    </div>
                </div>

                <div class="px-6 mt-auto">
                    <div class="bg-black/5 dark:bg-white/5 rounded-2xl p-4 relative overflow-hidden group">
                        <div class="absolute -right-4 -top-4 w-16 h-16 bg-gradient-to-br from-indigo-500 to-purple-500 rounded-full blur-xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
                        <h4 class="text-[12px] font-bold text-black dark:text-white mb-1">Расширенный доступ</h4>
                        <p class="text-[11px] text-gray-500 dark:text-gray-400 mb-3">Получить полную статистику.</p>
                        <button class="w-full bg-black dark:bg-white text-white dark:text-black text-[12px] font-bold py-2 rounded-xl hover:scale-105 transition-transform">
                            Обновить
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Main Dashboard Area -->
    <div class="flex-1 h-full pt-20 lg:pt-3 p-3 lg:p-3 overflow-hidden relative flex flex-col">
        <div class="w-full h-full bg-white/40 dark:bg-[#111]/40 backdrop-blur-xl lg:rounded-[32px] rounded-2xl border border-white dark:border-white/5 shadow-sm flex flex-col overflow-hidden relative dashboard-main-content">
            
            {% block dashboard_content %}
            <!-- Dashboard Header -->
            <header class="px-8 py-6 flex flex-col md:flex-row md:items-center justify-between gap-6 shrink-0 z-10">
                <div class="greeting-anim">
                    <h1 class="text-3xl font-light text-black dark:text-white tracking-tight">Обзор платформы</h1>
                    <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">С возвращением! Вот краткая статистика вашего бизнеса.</p>
                </div>
                
                <div class="flex items-center gap-4 greeting-anim" style="--stagger: 2;">
                    <!-- Search -->
                    <div class="relative hidden sm:block">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        </div>
                        <input type="text" class="bg-white/60 dark:bg-black/40 border border-black/10 dark:border-white/10 rounded-full pl-10 pr-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-black/20 dark:focus:ring-white/20 w-64 backdrop-blur-sm transition-all" placeholder="Поиск...">
                    </div>
                    
                    <!-- Notification -->
                    <button class="w-10 h-10 rounded-full bg-white/60 dark:bg-black/40 border border-black/10 dark:border-white/10 flex items-center justify-center hover:bg-white transition-colors relative">
                        <span class="absolute top-2 right-2.5 w-2 h-2 rounded-full bg-red-500 border border-white dark:border-current"></span>
                        <svg class="w-5 h-5 text-gray-600 dark:text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                    </button>
                </div>
            </header>

            <!-- Dashboard Content Grid -->
            <div class="flex-1 overflow-y-auto custom-scrollbar px-8 pb-8 z-10">
                
                <!-- Time Filter row -->
                <div class="flex items-center flex-wrap gap-4 mb-8 dashboard-card" style="--stagger: 3;">
                    <div class="flex bg-black/5 dark:bg-white/5 rounded-full p-1 border border-black/5 dark:border-white/5 transition-all">
                        <a href="{{ path('app_admin_dashboard', {period: 'day'}) }}" class="px-4 py-1.5 rounded-full text-xs font-semibold transition-all {{ currentPeriod == 'day' ? 'bg-white dark:bg-[#1a1a1a] text-black dark:text-white shadow-sm' : 'text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white' }}">День</a>
                        <a href="{{ path('app_admin_dashboard', {period: 'week'}) }}" class="px-4 py-1.5 rounded-full text-xs font-semibold transition-all {{ currentPeriod == 'week' ? 'bg-white dark:bg-[#1a1a1a] text-black dark:text-white shadow-sm' : 'text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white' }}">Неделя</a>
                        <a href="{{ path('app_admin_dashboard', {period: 'month'}) }}" class="px-4 py-1.5 rounded-full text-xs font-semibold transition-all {{ currentPeriod == 'month' ? 'bg-white dark:bg-[#1a1a1a] text-black dark:text-white shadow-sm' : 'text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white' }}">Месяц</a>
                        <a href="{{ path('app_admin_dashboard', {period: 'year'}) }}" class="px-4 py-1.5 rounded-full text-xs font-semibold transition-all {{ currentPeriod == 'year' ? 'bg-white dark:bg-[#1a1a1a] text-black dark:text-white shadow-sm' : 'text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white' }}">Год</a>
                        <a href="{{ path('app_admin_dashboard', {period: 'all'}) }}" class="px-4 py-1.5 rounded-full text-xs font-semibold transition-all {{ currentPeriod == 'all' or not currentPeriod ? 'bg-white dark:bg-[#1a1a1a] text-black dark:text-white shadow-sm' : 'text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white' }}">Всё время</a>
                    </div>
                </div>

                <!-- Main Stats Row -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
                    <!-- Stat Card 1 -->
                    <div class="bg-white/80 dark:bg-[#1a1a1a]/80 backdrop-blur-md rounded-3xl p-6 border border-black/5 dark:border-white/5 shadow-sm dashboard-card" style="--stagger: 4;">
                        <h4 class="text-gray-500 dark:text-gray-400 text-sm font-medium mb-4">Статей в блоге</h4>
                        <div class="text-4xl font-light text-black dark:text-white mb-4">{{ stats.articles|default(0) }}</div>
                        <div class="flex items-center text-xs font-medium text-green-500 dark:text-green-400">
                             Опубликовано материалов
                        </div>
                    </div>

                    <!-- Stat Card 2 -->
                    <div class="bg-white/80 dark:bg-[#1a1a1a]/80 backdrop-blur-md rounded-3xl p-6 border border-black/5 dark:border-white/5 shadow-sm dashboard-card" style="--stagger: 5;">
                        <h4 class="text-gray-500 dark:text-gray-400 text-sm font-medium mb-4">Черновиков</h4>
                        <div class="text-4xl font-light text-black dark:text-white mb-4">{{ stats.drafts|default(0) }}</div>
                        <div class="flex items-center text-xs font-medium text-amber-500 dark:text-amber-400">
                             Ожидают доработки
                        </div>
                    </div>

                    <!-- Stat Card 3 -->
                    <div class="bg-white/80 dark:bg-[#1a1a1a]/80 backdrop-blur-md rounded-3xl p-6 border border-black/5 dark:border-white/5 shadow-sm dashboard-card" style="--stagger: 6;">
                        <h4 class="text-gray-500 dark:text-gray-400 text-sm font-medium mb-4">Категорий</h4>
                        <div class="text-4xl font-light text-black dark:text-white mb-4">{{ stats.categories|default(0) }}</div>
                        <div class="flex items-center text-xs font-medium text-indigo-500 dark:text-indigo-400">
                             Рубрик создано
                        </div>
                    </div>

                    <!-- Stat Card 4 -->
                    <div class="bg-white/80 dark:bg-[#1a1a1a]/80 backdrop-blur-md rounded-3xl p-6 border border-black/5 dark:border-white/5 shadow-sm dashboard-card" style="--stagger: 7;">
                        <h4 class="text-gray-500 dark:text-gray-400 text-sm font-medium mb-4">Промо-акций</h4>
                        <div class="text-4xl font-light text-black dark:text-white mb-4">{{ stats.promos|default(0) }}</div>
                        <div class="flex items-center text-xs font-medium text-red-500 dark:text-red-400">
                             Активных объявлений
                        </div>
                    </div>
                </div>

                <!-- Complex Section -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <!-- Chart Area -->
                    <div class="lg:col-span-2 bg-white/80 dark:bg-[#1a1a1a]/80 backdrop-blur-md rounded-3xl p-6 border border-black/5 dark:border-white/5 shadow-sm flex flex-col dashboard-card" style="--stagger: 8;">
                        <div class="flex items-center justify-between mb-8">
                            <h3 class="font-bold text-lg text-black dark:text-white">Обзор производительности</h3>
                            <button class="w-8 h-8 rounded-full border border-black/10 dark:border-white/10 flex items-center justify-center text-gray-500 hover:bg-black/5 dark:hover:bg-white/5 transition-colors">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"/></svg>
                            </button>
                        </div>
                        
                        <!-- Real bar chart -->
                        <div class="flex-1 flex items-end justify-between gap-2 h-48 mt-auto px-4 pb-2">
                            {% set maxVal = 0 %}
                            {% for dp in chartData|default([]) %}
                                {% if dp.value > maxVal %}{% set maxVal = dp.value %}{% endif %}
                            {% endfor %}
                            {% set maxVal = maxVal > 0 ? maxVal : 1 %}

                            {% for dp in chartData|default([]) %}
                                <div class="w-full bg-black/5 dark:bg-white/5 rounded-t-xl relative group h-full flex items-end justify-center">
                                    <div class="w-full max-w-[40px] bg-indigo-500/20 dark:bg-indigo-500/10 rounded-t-lg transition-all duration-700 ease-in-out group-hover:bg-indigo-500" style="height: {{ (dp.value / maxVal) * 100 }}%;">
                                        <div class="w-full bg-indigo-500 h-full rounded-t-lg opacity-40 group-hover:opacity-100"></div>
                                    </div>
                                    <!-- Tooltip -->
                                    <div class="absolute -top-10 bg-indigo-600 dark:bg-indigo-500 text-white text-[10px] font-black px-2 py-1 rounded-full opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none shadow-xl">
                                        {{ dp.value }} ст.
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        <div class="flex justify-between px-4 pt-4 text-[9px] font-black uppercase tracking-widest text-gray-400 mt-2 border-t border-black/5 dark:border-white/5">
                            {% for dp in chartData|default([]) %}
                                <span class="text-center flex-1">{{ dp.label }}</span>
                            {% endfor %}
                        </div>
                    </div>

                    <!-- Side Widget Area -->
                    <div class="flex flex-col gap-6 dashboard-card" style="--stagger: 9;">
                        <!-- Mini Calendar/Progress -->
                        <div class="bg-white/80 dark:bg-[#1a1a1a]/80 backdrop-blur-md rounded-3xl p-6 border border-black/5 dark:border-white/5 shadow-sm">
                            <h3 class="font-bold text-[15px] text-black dark:text-white mb-6">Статус выполнения</h3>
                            <div class="space-y-4">
                                <div>
                                    <div class="flex justify-between text-xs mb-1">
                                        <span class="text-gray-500 font-medium">Завершено</span>
                                        <span class="font-bold">65%</span>
                                    </div>
                                    <div class="w-full bg-black/5 dark:bg-white/5 rounded-full h-2">
                                        <div class="bg-black dark:bg-white h-2 rounded-full" style="width: 65%"></div>
                                    </div>
                                </div>
                                <div>
                                    <div class="flex justify-between text-xs mb-1">
                                        <span class="text-gray-500 font-medium">В процессе</span>
                                        <span class="font-bold">30%</span>
                                    </div>
                                    <div class="w-full bg-black/5 dark:bg-white/5 rounded-full h-2">
                                        <div class="bg-gray-400 h-2 rounded-full" style="width: 30%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Action Card -->
                        <div class="bg-gradient-to-br from-black to-gray-800 dark:from-white dark:to-gray-200 rounded-3xl p-6 text-white dark:text-black shadow-xl relative overflow-hidden flex-1 flex flex-col justify-between">
                            <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4xKSIvPjwvc3ZnPg==')] opacity-30"></div>
                            
                            <div class="relative z-10">
                                <div class="w-10 h-10 bg-white/20 dark:bg-black/10 rounded-full flex items-center justify-center backdrop-blur-sm mb-4">
                                    <svg class="w-5 h-5 text-current" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                </div>
                                <h3 class="font-bold text-lg mb-2 text-current">Новая статья</h3>
                                <p class="text-xs text-white/60 dark:text-black/60 leading-relaxed mb-6">Создайте новый материал для блога прямо сейчас.</p>
                            </div>
                            
                            <a href="{{ path('app_admin_blog_create') }}" class="w-full bg-white dark:bg-black text-black dark:text-white rounded-xl py-3 text-sm font-bold relative z-10 hover:shadow-lg hover:scale-[1.02] transition-all text-center">
                                Начать
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            {% endblock %}
        </div>
    </div>
</div>
{% endblock %}
