{% extends 'admin/base.html.twig' %}

{% block title %}Log in - RDN Admin{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center bg-[#050505] relative overflow-hidden login-page">
    <!-- Background glows -->
    <div class="absolute w-[600px] h-[600px] bg-white/5 rounded-full blur-[100px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none fade-in-element"></div>
    <div class="absolute w-[800px] h-[800px] border border-white/5 rounded-full top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none animate-spin-slow mix-blend-screen scale-up-element opacity-20"></div>

    <div class="relative z-10 w-full max-w-md p-8 bg-white/[0.03] backdrop-blur-2xl border border-white/10 rounded-3xl shadow-[0_0_50px_rgba(255,255,255,0.05)] login-container">
        
        <div class="text-center mb-10 login-header">
            <div class="w-16 h-16 bg-white/10 rounded-2xl mx-auto flex items-center justify-center border border-white/10 mb-6 backdrop-blur-md">
                <svg class="w-8 h-8 text-white stroke-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                </svg>
            </div>
            <h1 class="text-3xl font-light text-white mb-2 tracking-wide">RDN Admin</h1>
            <p class="text-white/40 text-sm">Sign in to your dashboard</p>
        </div>

        <form method="post" class="space-y-6">
            {% if error %}
                <div class="p-3 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm text-center login-input-group">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <div class="space-y-2 login-input-group relative">
                <label for="username" class="text-[11px] font-semibold text-white/50 uppercase tracking-widest ml-1 block">Email Address</label>
                <div class="relative">
                    <input type="email" value="{{ last_username }}" name="_username" id="username" class="w-full bg-white/[0.03] border border-white/10 text-white rounded-xl px-5 py-3.5 focus:outline-none focus:border-white/30 focus:bg-white/10 transition-all duration-300 placeholder:text-white/20 peer" autocomplete="email" required autofocus placeholder="admin@rdn.by">
                    <div class="absolute inset-0 rounded-xl border border-white opacity-0 peer-focus:opacity-20 transition-opacity duration-300 pointer-events-none"></div>
                </div>
            </div>

            <div class="space-y-2 login-input-group relative">
                <label for="password" class="text-[11px] font-semibold text-white/50 uppercase tracking-widest ml-1 block block flex justify-between">
                    <span>Password</span>
                </label>
                <div class="relative">
                    <input type="password" name="_password" id="password" class="w-full bg-white/[0.03] border border-white/10 text-white rounded-xl px-5 py-3.5 focus:outline-none focus:border-white/30 focus:bg-white/10 transition-all duration-300 placeholder:text-white/20 peer" autocomplete="current-password" required placeholder="••••••••">
                    <div class="absolute inset-0 rounded-xl border border-white opacity-0 peer-focus:opacity-20 transition-opacity duration-300 pointer-events-none"></div>
                </div>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="login-btn-container pt-2">
                <button class="w-full bg-white text-black font-semibold rounded-xl py-3.5 mt-2 hover:bg-gray-200 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300 shadow-[0_0_20px_rgba(255,255,255,0.2)] hover:shadow-[0_0_30px_rgba(255,255,255,0.4)] flex items-center justify-center gap-2 group" type="submit">
                    <span>Sign In</span>
                    <svg class="w-5 h-5 opacity-50 group-hover:opacity-100 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                </button>
            </div>
        </form>
        
        <div class="mt-8 text-center login-input-group">
            <a href="/" class="text-xs text-white/30 hover:text-white transition-colors duration-300 flex items-center justify-center gap-1">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Back to website
            </a>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    // We defer the execution to allow the DOM and GSAP to fully initialize
    setTimeout(() => {
        if(typeof gsap !== 'undefined') {
            gsap.from('.login-container', {
                y: 60,
                opacity: 0,
                scale: 0.95,
                duration: 1.2,
                ease: 'expo.out'
            });

            gsap.from('.login-header', {
                y: 30,
                opacity: 0,
                duration: 1,
                delay: 0.2,
                ease: 'expo.out'
            });

            gsap.from('.login-input-group', {
                y: 20,
                opacity: 0,
                duration: 0.8,
                stagger: 0.15,
                delay: 0.4,
                ease: 'expo.out'
            });

            gsap.from('.login-btn-container', {
                y: 20,
                opacity: 0,
                duration: 0.8,
                delay: 0.8,
                ease: 'expo.out'
            });
            
            gsap.from('.fade-in-element', {
                opacity: 0,
                duration: 2,
                delay: 0.5,
                ease: 'power2.inOut'
            });
            
            gsap.from('.scale-up-element', {
                scale: 0.5,
                opacity: 0,
                duration: 2.5,
                ease: 'elastic.out(1, 0.5)'
            });
        }
    }, 100);
});
</script>
{% endblock %}
