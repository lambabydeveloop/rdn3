{% extends 'admin/dashboard.html.twig' %}

{% block title %}Блог - RDN Admin{% endblock %}

{% block dashboard_content %}
    <header class="px-8 py-6 flex flex-col md:flex-row md:items-center justify-between gap-6 shrink-0 z-10">
        <div class="greeting-anim">
            <h1 class="text-3xl font-light text-black dark:text-white tracking-tight">Мои статьи</h1>
            <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">Управление блогом и контентом сайта.</p>
        </div>
        
        <div class="flex items-center gap-4 greeting-anim" style="--stagger: 2;">
            <a href="{{ path('app_admin_blog_create') }}" class="bg-black dark:bg-white text-white dark:text-black font-semibold py-2 px-6 rounded-xl hover:scale-105 transition-transform flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Добавить статью
            </a>
        </div>
    </header>

    <div class="flex-1 overflow-y-auto custom-scrollbar px-8 pb-8 z-10 flex flex-col gap-8">
        
        {% set published = articles|filter(a => a.status == 'published') %}
        {% set drafts = articles|filter(a => a.status == 'draft') %}

        <div class="bg-white/80 dark:bg-[#1a1a1a]/80 backdrop-blur-md rounded-3xl p-6 border border-black/5 dark:border-white/5 shadow-sm dashboard-card" style="--stagger: 3;">
            <h2 class="text-xl font-bold text-black dark:text-white mb-6">Опубликованные</h2>
            {% if published|length > 0 %}
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="text-gray-400 dark:text-gray-500 text-sm border-b border-black/5 dark:border-white/5">
                                <th class="pb-3 font-medium px-4">Заголовок</th>
                                <th class="pb-3 font-medium px-4">Slug</th>
                                <th class="pb-3 font-medium px-4">Дата создания</th>
                                <th class="pb-3 font-medium px-4text-right">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in published %}
                                <tr class="hover:bg-black/[0.02] dark:hover:bg-white/[0.02] transition-colors border-b border-black/5 dark:border-white/5 last:border-0">
                                    <td class="py-4 px-4 font-medium text-black dark:text-white truncate max-w-[200px]">{{ item.title }}</td>
                                    <td class="py-4 px-4 text-gray-500 text-sm truncate max-w-[150px]">{{ item.slug }}</td>
                                    <td class="py-4 px-4 text-gray-400 text-sm">{{ item.createdAt|date('d.m.Y H:i') }}</td>
                                    <td class="py-4 px-4 text-right">
                                        <a href="{{ path('app_admin_blog_edit', {id: item.id}) }}" class="text-indigo-500 hover:text-indigo-600 font-medium text-sm">Редактировать</a>
                                        <a href="{{ path('app_blog_show', {slug: item.slug}) }}" target="_blank" class="text-gray-400 hover:text-black dark:hover:text-white ml-3 font-medium text-sm">👁</a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-gray-500 italic text-sm py-4">Нет опубликованных статей.</p>
            {% endif %}
        </div>

        <div class="bg-white/80 dark:bg-[#1a1a1a]/80 backdrop-blur-md rounded-3xl p-6 border border-black/5 dark:border-white/5 shadow-sm dashboard-card" style="--stagger: 4;">
            <h2 class="text-xl font-bold text-black dark:text-white mb-6">Черновики</h2>
            {% if drafts|length > 0 %}
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="text-gray-400 dark:text-gray-500 text-sm border-b border-black/5 dark:border-white/5">
                                <th class="pb-3 font-medium px-4">Заголовок</th>
                                <th class="pb-3 font-medium px-4">Обновлено</th>
                                <th class="pb-3 font-medium px-4 text-right">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in drafts %}
                                <tr class="hover:bg-black/[0.02] dark:hover:bg-white/[0.02] transition-colors border-b border-black/5 dark:border-white/5 last:border-0">
                                    <td class="py-4 px-4 font-medium text-black dark:text-white truncate max-w-[300px]">{{ item.title }}</td>
                                    <td class="py-4 px-4 text-gray-400 text-sm">{{ (item.updatedAt ?: item.createdAt)|date('d.m.Y H:i') }}</td>
                                    <td class="py-4 px-4 text-right">
                                        <a href="{{ path('app_admin_blog_edit', {id: item.id}) }}" class="text-indigo-500 hover:text-indigo-600 font-medium text-sm">Редактировать</a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-gray-500 italic text-sm py-4">Нет черновиков.</p>
            {% endif %}
        </div>
        
    </div>
{% endblock %}
