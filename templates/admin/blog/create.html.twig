{% extends 'admin/dashboard.html.twig' %}

{% block title %}{{ article is defined ? 'Редактировать статью' : 'Новая статья' }} - RDN Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('assets/libs/choices/choices.min.css') }}" />
    <style>
        /* Editor.js Clean Styling to match Notion */
        .ce-block__content, .ce-toolbar__content {
            max-width: 800px;
        }
        .codex-editor__redactor {
            padding-bottom: 200px !important;
        }
        .ce-paragraph {
            font-size: 1.125rem;
            line-height: 1.7;
            color: inherit;
        }
        h2.ce-header { font-size: 2rem; font-weight: 700; margin-top: 2rem; margin-bottom: 1rem; color: inherit; }
        h3.ce-header { font-size: 1.5rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.75rem; color: inherit; }
        .ce-block--selected .ce-block__content {
            background: rgba(255,255,255,0.05);
            border-radius: 8px;
        }
        
        /* Choices.js Custom Styling */
        .choices__inner {
            background-color: transparent !important;
            border-radius: 0.75rem !important;
            border: 1px solid rgba(0,0,0,0.1) !important;
            padding: 8px 12px !important;
            min-height: 44px !important;
        }
        .dark .choices__inner {
            border-color: rgba(255,255,255,0.1) !important;
            background-color: rgba(255,255,255,0.05) !important;
        }
        .choices__list--multiple .choices__item {
            background-color: #6366f1 !important;
            border: none !important;
            border-radius: 6px !important;
            font-size: 11px !important;
            font-weight: 700 !important;
            text-transform: uppercase !important;
            letter-spacing: 0.05em !important;
        }
        .choices__list--dropdown {
            background-color: #fff !important;
            border-radius: 12px !important;
            border: 1px solid rgba(0,0,0,0.1) !important;
            overflow: hidden !important;
            z-index: 100 !important;
        }
        .dark .choices__list--dropdown {
            background-color: #1a1a1a !important;
            border-color: rgba(255,255,255,0.1) !important;
        }
        .choices__input {
            background-color: transparent !important;
            color: inherit !important;
        }
        
        /* Sidebar layout fix */
        #seo-sidebar.show {
            transform: translateX(0);
        }
    </style>
{% endblock %}

{% block dashboard_content %}
    <header class="px-4 md:px-8 py-4 flex flex-col md:flex-row md:items-center justify-between gap-4 shrink-0 z-40 border-b border-black/5 dark:border-white/5 bg-white/30 dark:bg-black/30 backdrop-blur-xl sticky top-0">
        <div class="greeting-anim flex items-center gap-4">
            <a href="{{ path('app_admin_blog_index') }}" class="text-gray-500 hover:text-black dark:hover:text-white transition-colors">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            </a>
            <div>
                <h1 class="text-lg md:text-xl font-bold text-black dark:text-white tracking-tight leading-tight">{{ article is defined ? 'Редактировать статью' : 'Новая статья' }}</h1>
                <p class="text-gray-500 dark:text-gray-400 text-[10px] md:text-xs mt-0.5" id="save-status">Не сохранено</p>
            </div>
        </div>
        
        <div class="flex flex-wrap items-center justify-end gap-2 md:gap-3 greeting-anim" style="--stagger: 2;">
            <button type="button" onclick="document.getElementById('instructions-modal').classList.remove('hidden')" class="text-xs font-medium text-gray-500 hover:text-black dark:hover:text-white transition-colors underline decoration-dashed underline-offset-4 mr-2 hidden lg:block whitespace-nowrap">
                Инструкция (MD)
            </button>
            <button type="button" onclick="toggleSeoPanel()" class="bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 text-black dark:text-white font-semibold py-2 px-3 md:px-4 rounded-xl hover:bg-black/10 dark:hover:bg-white/10 transition-colors flex items-center gap-2 text-xs md:text-sm whitespace-nowrap">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                SEO
            </button>
            <button id="btn-draft" class="bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 text-black dark:text-white font-semibold py-2 px-3 md:px-4 rounded-xl hover:bg-black/10 dark:hover:bg-white/10 transition-colors text-xs md:text-sm whitespace-nowrap">
                В черновик
            </button>
            <button id="btn-publish" class="bg-indigo-600 text-white font-semibold py-2 px-4 md:px-6 rounded-xl hover:bg-indigo-700 hover:shadow-lg hover:shadow-indigo-500/20 transition-all transform hover:scale-105 text-xs md:text-sm whitespace-nowrap">
                Опубликовать
            </button>
        </div>
    </header>

    <!-- SEO Sidebar Panel -->
    <aside id="seo-sidebar" class="fixed inset-y-0 right-0 w-80 bg-white/95 dark:bg-[#1a1a1a]/95 backdrop-blur-3xl border-l border-black/10 dark:border-white/10 shadow-2xl z-[100] transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]">
        <div class="h-full flex flex-col p-6 overflow-y-auto custom-scrollbar relative">
            <button type="button" onclick="toggleSeoPanel()" class="absolute top-6 right-6 text-gray-400 hover:text-black dark:hover:text-white transition-colors">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
            
            <h3 class="font-bold text-xl mb-8 mt-2 text-black dark:text-white tracking-tight">Настройки SEO</h3>
            
            <div class="space-y-5">
                <div>
                    <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">URL (Slug)</label>
                    <input type="text" id="seo-slug" class="w-full bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-indigo-500 transition-colors" value="{{ article is defined ? article.slug : '' }}" placeholder="generiruetsya-avtomaticheski">
                </div>
                
                <div>
                    <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Категории</label>
                    <select id="article-categories" multiple>
                        {% for cat in categories|default([]) %}
                            <option value="{{ cat.id }}" {% if article is defined and article.categories.contains(cat) %}selected{% endif %}>{{ cat.name }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Meta Title</label>
                    <input type="text" id="seo-title" class="w-full bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-indigo-500 transition-colors" value="{{ article is defined ? article.seoTitle : '' }}" placeholder="Название для поисковиков">
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Meta Description</label>
                    <textarea id="seo-description" rows="3" class="w-full bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-indigo-500 transition-colors" placeholder="Краткое описание для сниппета...">{{ article is defined ? article.seoDescription : '' }}</textarea>
                </div>

                <div class="mb-5">
                    <label class="block text-xs font-bold text-gray-500 mb-2 uppercase tracking-wide">Обложка</label>
                    <div id="cover-dropzone" class="w-full h-32 border-2 border-dashed border-gray-300 dark:border-gray-700 rounded-xl relative hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors cursor-pointer flex items-center justify-center overflow-hidden">
                        {% if article is defined and article.coverImage %}
                            <img src="{{ article.coverImage }}" id="cover-preview" class="w-full h-full object-cover">
                        {% else %}
                            <div id="cover-placeholder" class="text-center text-gray-400 p-4">
                                <svg class="w-6 h-6 mx-auto mb-1 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                <span class="text-xs font-medium">Загрузить фото (Click/Drop)</span>
                            </div>
                            <img src="" id="cover-preview" class="w-full h-full object-cover hidden">
                        {% endif %}
                        <input type="file" id="cover-upload-input" accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer">
                    </div>
                    <input type="hidden" id="seo-cover" value="{{ article is defined ? article.coverImage : '' }}">
                    <div id="cover-loading" class="text-xs text-indigo-500 mt-2 font-medium hidden">Загрузка...</div>
                </div>

                {% if article is defined %}
                <div class="pt-6 border-t border-black/10 dark:border-white/10 mt-6">
                    <button type="button" id="btn-delete" class="w-full bg-red-500/10 text-red-500 font-semibold py-2 px-4 rounded-xl hover:bg-red-500 hover:text-white transition-colors flex justify-center items-center gap-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        Удалить статью
                    </button>
                </div>
                {% endif %}
            </div>
        </div>
    </aside>

    <div class="flex-1 overflow-y-auto px-4 md:px-12 lg:px-24 py-12 z-10 flex gap-8 relative h-full">
        <!-- Editor Content Area -->
        <div class="flex-1 max-w-4xl mx-auto w-full flex flex-col min-h-max h-fit bg-white dark:bg-[#1a1a1a] rounded-[2rem] shadow-sm border border-black/5 dark:border-white/5 p-8 md:p-16 transition-all duration-300" id="editor-container">
            <input type="text" id="article-title" placeholder="Заголовок статьи" class="w-full text-4xl md:text-5xl font-bold bg-transparent border-none outline-none text-black dark:text-white placeholder:text-gray-300 dark:placeholder:text-gray-700 mb-8" value="{{ article is defined ? article.title : '' }}">
            
            <div id="editorjs" class="font-sans text-black dark:text-gray-200 flex-1 min-h-[70vh]"></div>
        </div>
    </div>

    <!-- Instructions Modal -->
    <div id="instructions-modal" class="fixed inset-0 z-[110] bg-black/60 backdrop-blur-sm hidden items-center justify-center p-4">
        <div class="bg-[#1a1a1a] border border-white/10 rounded-2xl max-w-md w-full shadow-2xl overflow-hidden transform transition-all">
            <div class="p-6 border-b border-white/5 flex justify-between items-center">
                <h3 class="text-xl font-bold text-white">Markdown shortcuts</h3>
                <button onclick="document.getElementById('instructions-modal').classList.add('hidden')" class="text-gray-400 hover:text-white">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <div class="p-6 space-y-4 text-sm text-gray-300">
                <div class="flex justify-between items-center bg-white/5 p-3 rounded-lg"><span class="font-mono text-indigo-400"># + пробел</span><span>Заголовок 1 (H1)</span></div>
                <div class="flex justify-between items-center bg-white/5 p-3 rounded-lg"><span class="font-mono text-indigo-400">## + пробел</span><span>Заголовок 2 (H2)</span></div>
                <div class="flex justify-between items-center bg-white/5 p-3 rounded-lg"><span class="font-mono text-indigo-400">### + пробел</span><span>Заголовок 3 (H3)</span></div>
                <div class="flex justify-between items-center bg-white/5 p-3 rounded-lg"><span class="font-mono text-indigo-400">- + пробел</span><span>Маркированный список</span></div>
                <div class="flex justify-between items-center bg-white/5 p-3 rounded-lg"><span class="font-mono text-indigo-400">1. + пробел</span><span>Нумерованный список</span></div>
                <div class="flex justify-between items-center bg-white/5 p-3 rounded-lg"><span class="font-mono text-indigo-400">> + пробел</span><span>Цитата</span></div>
                <div class="text-xs text-center text-gray-500 mt-4">Или используйте кнопку «+» на пустой строке и выделите текст для стилизации.</div>
            </div>
        </div>
    </div>
    
    <!-- Editor and Configuration Data Setup -->
    <script>
        window.articleData = {{ article is defined ? article.content|json_encode|raw : '{}' }};
        window.articleId = {{ article is defined ? article.id : 'null' }};
        
        function toggleSeoPanel() {
            const sidebar = document.getElementById('seo-sidebar');
            sidebar.classList.toggle('translate-x-full');
        }
    </script>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <!-- Load Editor.js libraries -->
    <script src="{{ asset('assets/libs/editorjs/editorjs.umd.js') }}"></script>
    <script src="{{ asset('assets/libs/editorjs/header.umd.js') }}"></script>
    <script src="{{ asset('assets/libs/editorjs/editorjs-list.umd.js') }}"></script>
    <script src="{{ asset('assets/libs/editorjs/image.umd.js') }}"></script>
    <script src="{{ asset('assets/libs/editorjs/quote.umd.js') }}"></script>
    <script src="{{ asset('assets/libs/editorjs/marker.umd.js') }}"></script>
    <script src="{{ asset('assets/libs/editorjs/delimiter.umd.js') }}"></script>
    <script src="{{ asset('assets/libs/editorjs/code.umd.js') }}"></script>
    
    <!-- Load custom admin editor logic -->
    <script src="{{ asset('assets/js/admin-editor.js') }}"></script>
    
    <!-- Load Choices.js and initialize -->
    <script src="{{ asset('assets/libs/choices/choices.min.js') }}"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const categorySelect = document.getElementById('article-categories');
            if (categorySelect && typeof Choices !== 'undefined') {
                new Choices(categorySelect, {
                    removeItemButton: true,
                    placeholder: true,
                    placeholderValue: 'Выберите категории',
                    searchPlaceholderValue: 'Поиск...',
                    noChoicesText: 'Нет категорий',
                    itemSelectText: '',
                    shouldSort: false
                });
            }
        });
    </script>
{% endblock %}
