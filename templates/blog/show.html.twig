{% extends 'base.html.twig' %}

{# Custom SEO Meta #}
{% block title %}{{ article.seoTitle ?: article.title }} - RDN{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- Schema.org JSON-LD Configuration -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ absolute_url(path('app_blog_show', {slug: article.slug})) }}"
      },
      "headline": "{{ article.title|escape('js') }}",
      {% if article.seoDescription %}
      "description": "{{ article.seoDescription|escape('js') }}",
      {% endif %}
      {% if article.coverImage %}
      "image": "{{ absolute_url(article.coverImage) }}",
      {% endif %}  
      "datePublished": "{{ article.createdAt|date('c') }}",
      "dateModified": "{{ (article.updatedAt ?: article.createdAt)|date('c') }}",
      "author": {
        "@type": "Organization",
        "name": "RDN"
      },
      "publisher": {
        "@type": "Organization",
        "name": "RDN",
        "logo": {
          "@type": "ImageObject",
          "url": "{{ absolute_url('/logo.png') }}"
        }
      }
    }
    </script>
    
    <style>
        .article-content {
            font-size: 1.125rem;
            line-height: 1.8;
            color: inherit;
        }
        .article-content p { margin-bottom: 1.5rem; }
        .article-content h2 { font-size: 2rem; font-weight: 800; margin-top: 3rem; margin-bottom: 1.5rem; color: var(--tw-prose-headings); }
        .article-content h3 { font-size: 1.5rem; font-weight: 700; margin-top: 2rem; margin-bottom: 1rem; color: var(--tw-prose-headings); }
        .article-content h4 { font-size: 1.25rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 1rem; color: var(--tw-prose-headings); }
        .article-content ul { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 1.5rem; }
        .article-content ol { list-style-type: decimal; padding-left: 1.5rem; margin-bottom: 1.5rem; }
        .article-content li { margin-bottom: 0.5rem; }
        .article-content blockquote {
            border-left: 4px solid #6366f1; /* Indigo-500 */
            background: rgba(99, 102, 241, 0.05);
            padding: 1.5rem;
            border-radius: 0 1rem 1rem 0;
            font-style: italic;
            margin: 2.5rem 0;
            opacity: 0.95;
        }
        .article-content blockquote footer {
            display: block;
            margin-top: 1rem;
            font-size: 0.875rem;
            font-weight: 600;
            opacity: 0.7;
            font-style: normal;
        }
        .article-content figure {
            margin: 3.5rem 0;
            border-radius: 1.5rem;
            overflow: hidden;
            background: rgba(0,0,0,0.03);
            border: 1px solid rgba(0,0,0,0.05);
        }
        .dark .article-content figure {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
        }
        .article-content figure img {
            width: 100%;
            height: auto;
            display: block;
        }
        .article-content figcaption {
            text-align: center;
            padding: 1rem 1.5rem;
            font-size: 0.875rem;
            opacity: 0.6;
            margin: 0;
        }
        .article-content mark.cdx-marker {
            background-color: rgba(99, 102, 241, 0.2);
            color: inherit;
            padding: 0 4px;
            border-radius: 4px;
        }
    </style>
{% endblock %}

{% block meta %}
    <meta name="title" content="{{ article.seoTitle ?: article.title }}">
    {% if article.seoDescription %}
    <meta name="description" content="{{ article.seoDescription }}">
    {% endif %}
{% endblock %}

{% block body %}

<div class="pt-32 pb-24 px-4 sm:px-8 bg-gray-50 dark:bg-black/5 min-h-screen">
    
    <div class="max-w-[1600px] mx-auto flex flex-col xl:flex-row gap-8 items-start">
        
        <!-- Left Sidebar: Tree & Back button -->
        <aside class="w-full xl:w-72 shrink-0 xl:sticky xl:top-32 hidden lg:flex flex-col gap-6 z-10">
            <a href="{{ path('app_blog_index') }}" class="inline-flex items-center gap-3 text-gray-500 hover:text-black dark:text-gray-400 dark:hover:text-white font-medium transition-colors group px-2">
                <div class="w-10 h-10 rounded-full bg-white dark:bg-[#1a1a1a] shadow-sm flex items-center justify-center group-hover:-translate-x-1 group-hover:bg-indigo-500 group-hover:text-white transition-all transform border border-black/5 dark:border-white/5">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                </div>
                Вернуться в блог
            </a>

            <div class="bg-white dark:bg-[#1a1a1a] rounded-[2rem] p-8 shadow-sm border border-black/5 dark:border-white/5 flex flex-col gap-4">
                <h3 class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-2">Последние статьи</h3>
                
                <div class="flex flex-col gap-4 w-full" x-data="{ openFolder: '{{ article.categories|first ? article.categories|first.id : 0 }}' }">
                    {% for catNode in categoriesTree|default([]) %}
                        <div class="category-folder">
                            <button @click="openFolder = (openFolder == '{{ catNode.category.id }}' ? 0 : '{{ catNode.category.id }}')" 
                                    class="w-full flex items-center justify-between group/btn mb-2 text-black dark:text-white font-black tracking-wide text-sm outline-none">
                                <div class="flex items-center gap-2">
                                    <svg class="w-4 h-4 text-indigo-500 transition-transform" :class="openFolder == '{{ catNode.category.id }}' ? 'rotate-0' : '-rotate-90'" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                                    {{ catNode.category.name|upper }}
                                </div>
                                <span class="text-[10px] bg-black/5 dark:bg-white/5 px-1.5 py-0.5 rounded opacity-40">{{ catNode.articles|length }}</span>
                            </button>
                            
                            <ul class="flex flex-col gap-4 relative pl-2 overflow-hidden transition-all duration-300" 
                                x-show="openFolder == '{{ catNode.category.id }}'"
                                x-transition:enter="transition ease-out duration-200"
                                x-transition:enter-start="opacity-0 -translate-y-2"
                                x-transition:enter-end="opacity-100 translate-y-0">
                                <div class="absolute left-2.5 top-2 bottom-2 w-px bg-black/10 dark:bg-white/10 -z-10"></div>
                                {% for recent in catNode.articles %}
                                    <li class="relative pl-6 group">
                                        <div class="absolute left-1.5 top-2 w-2 h-2 rounded-full ring-4 transition-all {% if recent.id == article.id %}bg-indigo-500 ring-indigo-500/20{% else %}bg-black/20 dark:bg-white/20 ring-white dark:ring-[#1a1a1a] group-hover:bg-indigo-400 group-hover:scale-125{% endif %}"></div>
                                        <a href="{{ path('app_blog_show', {slug: recent.slug}) }}" class="block text-sm font-medium line-clamp-2 leading-snug transition-colors {% if recent.id == article.id %}text-indigo-600 dark:text-indigo-400 underline decoration-indigo-500/30 underline-offset-4{% else %}text-gray-600 dark:text-gray-400 hover:text-indigo-500{% endif %}">
                                            {{ recent.title }}
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </aside>

        <!-- Main Content (Middle Col) -->
        <main class="flex-1 min-w-0 w-full relative z-10">
            <!-- Mobile Navigation (visible on tablets/mobiles) -->
            <div class="lg:hidden mb-8 px-4 flex items-center justify-between">
                <a href="{{ path('app_blog_index') }}" class="inline-flex items-center gap-2 text-gray-500 hover:text-black dark:text-gray-400 dark:hover:text-white font-medium transition-colors group">
                    <div class="w-8 h-8 rounded-full bg-white dark:bg-[#1a1a1a] shadow-sm flex items-center justify-center group-hover:-translate-x-1 transition-all border border-black/5 dark:border-white/5">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                    </div>
                    Вернуться в блог
                </a>
            </div>

            <!-- Draft Alert -->
            {% if article.status == 'draft' %}
                <div class="mb-4 bg-amber-500/10 border border-amber-500/20 text-amber-600 dark:text-amber-400 rounded-3xl p-4 text-center font-medium backdrop-blur-md mx-4 lg:mx-0">
                    ⚠️ Черновик. Недоступно публично.
                </div>
            {% endif %}

            <article class="bg-white dark:bg-[#1a1a1a] shadow-sm border border-black/5 dark:border-white/5 rounded-[2.5rem] overflow-hidden text-black dark:text-[rgba(255,255,255,0.85)] flex flex-col w-full h-full relative">
                
                {% if article.coverImage %}
                    <div class="w-full h-[50vh] xl:h-[60vh] relative bg-black">
                        <img src="{{ article.coverImage }}" alt="{{ article.title }}" class="absolute inset-0 w-full h-full object-cover">
                        <div class="absolute inset-0 bg-gradient-to-at from-black/80 via-black/20 to-transparent"></div>
                        <div class="absolute bottom-0 left-0 right-0 p-8 md:p-16 lg:p-24 z-10">
                            <div class="text-xs md:text-sm font-semibold text-white/80 mb-4 uppercase tracking-widest flex items-center flex-wrap gap-x-4 gap-y-2">
                                <div class="flex items-center gap-2">
                                    <div class="w-6 h-6 rounded-full bg-white/20 flex items-center justify-center shrink-0">
                                        <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                    </div>
                                    <span>RDN.BY</span>
                                </div>
                                <span class="opacity-50">•</span>
                                <span>{{ article.createdAt|date('d.m.Y H:i') }}</span>
                                {% if article.updatedAt and article.updatedAt > article.createdAt %}
                                    <span class="opacity-50">•</span> <span>Обновлено {{ article.updatedAt|date('d.m.Y H:i') }}</span>
                                {% endif %}
                                
                                {% if article.categories|length > 0 %}
                                    <span class="opacity-50">•</span>
                                    <div class="flex gap-2">
                                        {% for cat in article.categories %}
                                            <span class="px-2 py-0.5 rounded-md bg-white/20 backdrop-blur-sm text-white text-[10px] font-bold">{{ cat.name }}</span>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            <h1 class="text-4xl md:text-5xl lg:text-7xl font-black mb-0 leading-[1.1] tracking-tight text-white max-w-5xl text-wrap">{{ article.title }}</h1>
                        </div>
                    </div>
                {% endif %}

                <div class="{{ article.coverImage ? 'pt-8 md:pt-16' : 'pt-16' }} px-8 md:px-16 lg:px-24">
                    {% if not article.coverImage %}
                        <header class="mb-12 border-b border-black/5 dark:border-white/5 pb-8">
                            <div class="text-xs font-semibold text-indigo-500 mb-4 uppercase tracking-widest flex items-center flex-wrap gap-x-4 gap-y-2">
                                <span>Авторы RDN.BY</span>
                                <span class="text-gray-400">•</span>
                                <span>{{ article.createdAt|date('d.m.Y H:i') }}</span>
                                {% if article.updatedAt and article.updatedAt > article.createdAt %}
                                    <span class="text-gray-400">•</span> <span class="text-gray-400">Обновлено {{ article.updatedAt|date('d.m.Y H:i') }}</span>
                                {% endif %}
                                
                                {% if article.categories|length > 0 %}
                                    <span class="text-gray-400">•</span>
                                    <div class="flex gap-2">
                                        {% for cat in article.categories %}
                                            <span class="px-2 py-0.5 rounded-md bg-indigo-50 dark:bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 text-[10px] font-bold border border-indigo-200 dark:border-indigo-500/20">{{ cat.name }}</span>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            <h1 class="text-4xl md:text-5xl lg:text-7xl font-black mb-6 leading-[1.1] tracking-tight text-black dark:text-white">{{ article.title }}</h1>
                        </header>
                    {% endif %}

                    {% if article.seoDescription %}
                        <p class="text-xl md:text-2xl text-gray-500 dark:text-gray-400 italic mb-12 {{ not article.coverImage ? 'mt-8' : '' }} border-l-4 border-indigo-500 pl-6 lg:pl-8 font-light leading-relaxed">{{ article.seoDescription }}</p>
                    {% endif %}
                </div>

    {% set hasHeaders = false %}
    {% for block in article.content.blocks|default([]) %}
        {% if block.type == 'header' %}
            {% set hasHeaders = true %}
        {% endif %}
    {% endfor %}

    {% if hasHeaders %}
    <div class="px-8 md:px-16 lg:px-24 mb-10 max-w-5xl">
        <div class="bg-gray-50 dark:bg-black/20 border border-black/5 dark:border-white/5 rounded-2xl p-6 md:p-8">
            <h4 class="text-sm font-black text-black dark:text-white uppercase tracking-widest border-b border-black/5 dark:border-white/5 pb-4 mb-4">Содержание статьи</h4>
            <ul class="flex flex-col gap-3">
                {% set headerIndex = 0 %}
                {% for block in article.content.blocks|default([]) %}
                    {% if block.type == 'header' %}
                        {% set headerIndex = headerIndex + 1 %}
                        {% set isH3 = block.data.level >= 3 %}
                        <li class="{% if isH3 %}pl-6 text-sm text-gray-500{% else %}text-base font-medium text-indigo-600 dark:text-indigo-400{% endif %}">
                            <a href="#header-{{ loop.index }}" class="hover:underline decoration-dashed underline-offset-4">{{ block.data.text|striptags }}</a>
                        </li>
                    {% endif %}
                {% endfor %}
            </ul>
        </div>
    </div>
    {% endif %}

    <!-- Mobile Only Ad Section -->
    {% if promos|length > 0 %}
        {% set mPromo = promos|first %}
        <div class="xl:hidden mx-8 md:mx-16 lg:px-24 mb-12">
            <div class="bg-{{ mPromo.styleName == 'dark' ? 'black' : 'white' }} dark:bg-[#1a1a1a] rounded-[2rem] overflow-hidden shadow-sm border border-black/5 dark:border-white/5 relative group p-8 flex flex-col items-start gap-4 justify-between min-h-[250px]">
                <div class="absolute inset-0 {{ mPromo.styleName == 'dark' ? 'opacity-10' : 'bg-gradient-to-br from-indigo-500/10 via-purple-500/5 to-transparent' }} z-0"></div>
                <div class="relative z-10 w-full">
                    {% if mPromo.label %}
                        <div class="text-[0.65rem] font-bold tracking-widest uppercase text-indigo-500 dark:text-indigo-400 mb-2">{{ mPromo.label }}</div>
                    {% endif %}
                    <h3 class="text-xl font-black text-{{ mPromo.styleName == 'dark' ? 'white' : 'black' }} dark:text-white mb-3">{{ mPromo.title }}</h3>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mb-6 leading-relaxed">{{ mPromo.description }}</p>
                </div>
                {% if mPromo.url %}
                    <a href="{{ mPromo.url }}" class="relative z-10 inline-flex items-center justify-center w-full bg-{{ mPromo.styleName == 'dark' ? 'white' : 'black' }} dark:bg-white text-{{ mPromo.styleName == 'dark' ? 'black' : 'white' }} dark:text-black font-semibold py-3 px-6 rounded-xl hover:bg-indigo-500 dark:hover:bg-indigo-500 hover:text-white dark:hover:text-white transition-colors text-center shadow-lg">
                        {{ mPromo.actionText|default('Узнать больше') }}
                    </a>
                {% endif %}
            </div>
        </div>
    {% endif %}

    <div class="article-content px-8 md:px-16 lg:px-24 pb-16 lg:pb-32 max-w-5xl">
                    {% if article.content.blocks is defined %}
                        {% for block in article.content.blocks %}
                            
                            {% if block.type == 'paragraph' %}
                                <p>{{ block.data.text|raw }}</p>
                            
                            {% elseif block.type == 'header' %}
                                <h{{ block.data.level }} id="header-{{ loop.index }}" class="scroll-mt-32 {% if block.data.level == 2 %}mt-16{% else %}mt-12{% endif %}">{{ block.data.text|raw }}</h{{ block.data.level }}>

                            {% elseif block.type == 'code' %}
                                <div class="my-8 rounded-2xl overflow-hidden bg-[#1e1e1e] border border-white/10 shadow-2xl relative group">
                                    <div class="flex items-center justify-between px-4 py-2 bg-[#2d2d2d] border-b border-white/5">
                                        <div class="flex gap-2">
                                            <div class="w-3 h-3 rounded-full bg-red-500"></div>
                                            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                                            <div class="w-3 h-3 rounded-full bg-green-500"></div>
                                        </div>
                                        <button class="text-gray-400 hover:text-white text-xs font-mono uppercase tracking-widest transition-colors flex items-center gap-1 opacity-0 group-hover:opacity-100 copy-btn" data-code="{{ block.data.code|escape('html_attr') }}">
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg> <span>Копировать</span>
                                        </button>
                                    </div>
                                    <div class="p-4 overflow-x-auto custom-scrollbar">
                                        <pre><code class="font-mono text-sm text-[#d4d4d4] leading-relaxed">{{ block.data.code|escape('html') }}</code></pre>
                                    </div>
                                </div>

                            {% elseif block.type == 'quote' %}
                                <blockquote>
                                    <p class="text-xl">{{ block.data.text|raw }}</p>
                                    {% if block.data.caption %}
                                        <footer>— {{ block.data.caption|raw }}</footer>
                                    {% endif %}
                                </blockquote>
                                
                            {% elseif block.type == 'delimiter' %}
                                <div class="flex items-center justify-center my-16 gap-4">
                                    <div class="w-2 h-2 rounded-full bg-gray-300 dark:bg-gray-700"></div>
                                    <div class="w-2 h-2 rounded-full bg-gray-300 dark:bg-gray-700"></div>
                                    <div class="w-2 h-2 rounded-full bg-gray-300 dark:bg-gray-700"></div>
                                </div>
                            {% endif %}
                            
                            {% if loop.index % 4 == 0 and promos[(loop.index // 4) - 1] is defined %}
                                {% set mPromo = promos[(loop.index // 4) - 1] %}
                                <div class="xl:hidden my-12 bg-{{ mPromo.styleName == 'dark' ? 'black' : 'white' }} dark:bg-[#1a1a1a] rounded-[2rem] overflow-hidden shadow-sm border border-black/5 dark:border-white/5 relative group p-8 flex flex-col items-start gap-4 justify-between min-h-[250px]">
                                    <div class="absolute inset-0 {{ mPromo.styleName == 'dark' ? 'opacity-10' : 'bg-gradient-to-br from-indigo-500/10 via-purple-500/5 to-transparent' }} z-0"></div>
                                    <div class="relative z-10 w-full">
                                        {% if mPromo.label %}
                                            <div class="text-[0.65rem] font-bold tracking-widest uppercase text-indigo-500 dark:text-indigo-400 mb-2">{{ mPromo.label }}</div>
                                        {% endif %}
                                        <h4 class="text-lg font-black text-{{ mPromo.styleName == 'dark' ? 'white' : 'black' }} dark:text-white mb-3">{{ mPromo.title }}</h4>
                                        <p class="text-sm text-gray-500 dark:text-gray-400 mb-6 leading-relaxed">{{ mPromo.description }}</p>
                                    </div>
                                    {% if mPromo.url %}
                                        <a href="{{ mPromo.url }}" class="relative z-10 inline-flex items-center justify-center w-full bg-{{ mPromo.styleName == 'dark' ? 'white' : 'black' }} dark:bg-white text-{{ mPromo.styleName == 'dark' ? 'black' : 'white' }} dark:text-black font-semibold py-3 px-6 rounded-xl hover:bg-indigo-500 dark:hover:bg-indigo-500 hover:text-white dark:hover:text-white transition-colors text-center shadow-lg">
                                            {{ mPromo.actionText|default('Узнать больше') }}
                                        </a>
                                    {% endif %}
                                </div>
                            {% endif %}
                            
                        {% endfor %}
                    {% else %}
                        <p class="text-gray-500 italic text-center py-10">Контент пуст.</p>
                    {% endif %}
                </div>

                <!-- Mobile Only Category Tree Section at the bottom -->
                <div class="lg:hidden bg-gray-50 dark:bg-black/20 border-t border-black/5 dark:border-white/5 p-8" x-data="{ openFolder: '{{ article.categories|first ? article.categories|first.id : 0 }}' }">
                    <h3 class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-6">Навигация по категориям</h3>
                    <div class="flex flex-col gap-6 w-full">
                        {% for catNode in categoriesTree|default([]) %}
                            <div class="category-folder">
                                <button @click="openFolder = (openFolder == '{{ catNode.category.id }}' ? 0 : '{{ catNode.category.id }}')" 
                                        class="w-full flex items-center justify-between mb-2 text-black dark:text-white font-black tracking-wide text-sm outline-none">
                                    <div class="flex items-center gap-2">
                                        <svg class="w-4 h-4 text-indigo-500 transition-transform" :class="openFolder == '{{ catNode.category.id }}' ? 'rotate-0' : '-rotate-90'" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                                        {{ catNode.category.name|upper }}
                                    </div>
                                    <span class="text-[10px] bg-black/5 dark:bg-white/5 px-1.5 py-0.5 rounded opacity-40">{{ catNode.articles|length }}</span>
                                </button>
                                
                                <ul class="flex flex-col gap-4 relative pl-2 overflow-hidden transition-all duration-300" 
                                    x-show="openFolder == '{{ catNode.category.id }}'"
                                    x-transition:enter="transition ease-out duration-200"
                                    x-transition:enter-start="opacity-0 -translate-y-2"
                                    x-transition:enter-end="opacity-100 translate-y-0">
                                    <div class="absolute left-2.5 top-2 bottom-2 w-px bg-black/10 dark:bg-white/10 -z-10"></div>
                                    {% for recent in catNode.articles %}
                                        <li class="relative pl-6 group">
                                            <div class="absolute left-1.5 top-2 w-2 h-2 rounded-full ring-4 transition-all {% if recent.id == article.id %}bg-indigo-500 ring-indigo-500/20{% else %}bg-black/20 dark:bg-white/20 ring-white dark:ring-[#1a1a1a] group-hover:bg-indigo-400 group-hover:scale-125{% endif %}"></div>
                                            <a href="{{ path('app_blog_show', {slug: recent.slug}) }}" class="block text-sm font-medium line-clamp-2 leading-snug transition-colors {% if recent.id == article.id %}text-indigo-600 dark:text-indigo-400 underline decoration-indigo-500/30 underline-offset-4{% else %}text-gray-600 dark:text-gray-400 hover:text-indigo-500{% endif %}">
                                                {{ recent.title }}
                                            </a>
                                        </li>
                                    {% endfor %}
                                </ul>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                {% if recommendedArticles|length > 0 %}
                <section class="bg-gray-50/50 dark:bg-black/20 border-t border-black/5 dark:border-white/5 p-8 md:p-16 lg:p-24" x-data="{ showModal: false }">
                    <div class="flex items-center justify-between mb-12">
                        <h3 class="text-3xl font-black text-black dark:text-white tracking-tight">Рекомендуем к прочтению</h3>
                        <button @click="showModal = true" class="hidden md:flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-gray-400 hover:text-indigo-500 transition-colors">
                            Посмотреть все
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                        </button>
                    </div>

                    <!-- Recommended Bento Grid Style (Top 3) -->
                    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-12 h-auto lg:h-[500px]">
                        {% set top3 = recommendedArticles|slice(0, 3) %}
                        {% if top3|length >= 1 %}
                            <a href="{{ path('app_blog_show', {slug: top3[0].slug}) }}" class="lg:col-span-8 group relative bg-black rounded-[2.5rem] overflow-hidden shadow-2xl flex flex-col justify-end p-8 md:p-16">
                                <img src="{{ top3[0].coverImage|default('https://placehold.co/1200x800/222/FFF?text=Article+Header') }}" class="absolute inset-0 w-full h-full object-cover opacity-50 transition-transform duration-700 group-hover:scale-105">
                                <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent"></div>
                                <div class="relative z-10">
                                    <div class="flex items-center gap-3 mb-6">
                                        <span class="bg-indigo-500 text-white text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest">Must Read</span>
                                        <span class="text-white/60 text-xs font-bold">{{ top3[0].createdAt|date('d M Y') }}</span>
                                    </div>
                                    <h4 class="text-4xl md:text-5xl font-black text-white leading-[1.1] mb-4 group-hover:text-indigo-200 transition-colors uppercase">{{ top3[0].title }}</h4>
                                </div>
                            </a>
                        {% endif %}

                        <div class="lg:col-span-4 flex flex-col gap-8">
                            {% for recTarget in top3|slice(1, 2) %}
                                <a href="{{ path('app_blog_show', {slug: recTarget.slug}) }}" class="flex-1 bg-white dark:bg-[#1a1a1a] rounded-[2rem] p-8 border border-black/5 dark:border-white/5 flex flex-col justify-between group hover:shadow-xl transition-all">
                                    <div class="relative z-10">
                                        <div class="flex justify-between items-center mb-6">
                                            <span class="text-[10px] font-black uppercase tracking-widest text-indigo-500">{{ recTarget.categories|first ? recTarget.categories|first.name : 'Статья' }} / {{ recTarget.createdAt|date('d M') }}</span>
                                            <div class="h-px bg-black/10 dark:bg-white/10 flex-1 ml-4"></div>
                                        </div>
                                        <h4 class="text-2xl font-black text-black dark:text-white leading-tight mb-2 group-hover:text-indigo-500 transition-colors uppercase line-clamp-3">{{ recTarget.title }}</h4>
                                    </div>
                                </a>
                            {% endfor %}
                        </div>
                    </div>

                    <button @click="showModal = true" class="md:hidden w-full bg-black dark:bg-white text-white dark:text-black font-black py-4 rounded-2xl uppercase tracking-widest text-xs mb-8">
                        Все рекомендации
                    </button>

                    <!-- Modal for all recommendations -->
                    <div x-show="showModal" 
                         class="fixed inset-0 z-[100] flex items-center justify-center p-4 sm:p-8" 
                         x-cloak
                         @keydown.escape.window="showModal = false">
                        <div class="absolute inset-0 bg-black/60 backdrop-blur-md" @click="showModal = false"></div>
                        <div class="relative bg-white dark:bg-[#111] w-full max-w-2xl max-h-[80vh] rounded-[3rem] overflow-hidden flex flex-col shadow-2xl border border-white/5"
                             x-show="showModal"
                             x-transition:enter="transition ease-out duration-300 transform"
                             x-transition:enter-start="opacity-0 scale-95"
                             x-transition:enter-end="opacity-100 scale-100">
                            
                            <header class="p-8 border-b border-black/5 dark:border-white/5 flex items-center justify-between">
                                <h3 class="text-2xl font-black text-black dark:text-white uppercase">Все рекомендации</h3>
                                <button @click="showModal = false" class="w-10 h-10 rounded-full bg-black/5 dark:bg-white/5 flex items-center justify-center hover:bg-black/10 dark:hover:bg-white/10 transition-colors">
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                                </button>
                            </header>

                            <div class="flex-1 overflow-y-auto custom-scrollbar p-6 space-y-4">
                                {% for recTarget in recommendedArticles %}
                                    <a href="{{ path('app_blog_show', {slug: recTarget.slug}) }}" class="flex items-center gap-6 p-4 rounded-[1.5rem] hover:bg-black/5 dark:hover:bg-white/5 transition-colors group">
                                        <div class="w-24 h-24 rounded-2xl overflow-hidden shrink-0 bg-black">
                                            <img src="{{ recTarget.coverImage|default('https://placehold.co/200x200/222/FFF?text=Post') }}" class="w-full h-full object-cover">
                                        </div>
                                        <div class="flex-1">
                                            <div class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">{{ recTarget.createdAt|date('M d, Y') }}</div>
                                            <h4 class="text-lg font-black text-black dark:text-white leading-tight group-hover:text-indigo-500 transition-colors mb-2">{{ recTarget.title }}</h4>
                                            <div class="text-[10px] font-bold uppercase tracking-widest text-gray-400 flex items-center gap-1 group-hover:text-indigo-500 transition-colors">ЧИТАТЬ <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></div>
                                        </div>
                                    </a>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </section>
                {% endif %}

            </article>
        </main>

        <!-- Right Promo Sidebar -->
        <aside class="w-full xl:w-80 shrink-0 xl:sticky xl:top-32 hidden xl:flex flex-col gap-6 z-10">
            {% for promo in promos|default([]) %}
                <div class="bg-{{ promo.styleName == 'dark' ? 'black' : 'white' }} dark:bg-[#1a1a1a] rounded-[2rem] overflow-hidden shadow-sm border border-black/5 dark:border-white/5 relative group p-8 flex flex-col items-start gap-4 justify-between">
                    <div class="absolute inset-0 {{ promo.styleName == 'dark' ? 'opacity-10' : 'bg-gradient-to-br from-indigo-500/10 via-purple-500/5 to-transparent' }} z-0"></div>
                    <div class="relative z-10 w-full">
                        {% if promo.label %}
                            <div class="text-[0.65rem] font-bold tracking-widest uppercase text-indigo-500 dark:text-indigo-400 mb-2">{{ promo.label }}</div>
                        {% endif %}
                        <h3 class="text-xl font-black text-{{ promo.styleName == 'dark' ? 'white' : 'black' }} dark:text-white mb-3">{{ promo.title }}</h3>
                        <p class="text-sm text-gray-500 dark:text-gray-400 mb-6 leading-relaxed">{{ promo.description }}</p>
                    </div>
                    {% if promo.url %}
                        <a href="{{ promo.url }}" class="relative z-10 inline-flex items-center justify-center w-full bg-{{ promo.styleName == 'dark' ? 'white' : 'black' }} dark:bg-white text-{{ promo.styleName == 'dark' ? 'black' : 'white' }} dark:text-black font-semibold py-3 px-6 rounded-xl hover:bg-indigo-500 dark:hover:bg-indigo-500 hover:text-white dark:hover:text-white transition-colors text-center">
                            {{ promo.actionText|default('Узнать больше') }}
                        </a>
                    {% endif %}
                </div>
            {% else %}
                <div class="p-8 text-center text-sm text-gray-400 border border-dashed border-gray-300 dark:border-gray-700 rounded-[2rem]">
                    Будущие акции
                </div>
            {% endfor %}
        </aside>

    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.copy-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const code = btn.getAttribute('data-code');
                navigator.clipboard.writeText(code).then(() => {
                    const originalHTML = btn.innerHTML;
                    btn.innerHTML = '<span class="text-green-500">Скопировано!</span>';
                    setTimeout(() => btn.innerHTML = originalHTML, 2000);
                });
            });
        });
    });
</script>

{% endblock %}
