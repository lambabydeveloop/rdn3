{
    "scripts": {
        "build": "npm run build:css && npm run build:js",
        "build:css": "npx @tailwindcss/cli -i ./assets/styles/app.css -o ./public/assets/build/app.css --minify",
        "watch:css": "npx @tailwindcss/cli -i ./assets/styles/app.css -o ./public/assets/build/app.css --watch",
        "build:js": "npx terser public/assets/js/index_home.js -o public/assets/build/index_home.min.js -c -m"
    },
    "devDependencies": {
        "terser": "^5.30.0"
    },
    "dependencies": {
        "@editorjs/code": "^2.9.4",
        "@editorjs/delimiter": "^1.4.2",
        "@editorjs/editorjs": "^2.31.3",
        "@editorjs/header": "^2.8.8",
        "@editorjs/image": "^2.10.3",
        "@editorjs/list": "^2.0.9",
        "@editorjs/marker": "^1.4.0",
        "@editorjs/quote": "^2.7.6",
        "@tailwindcss/cli": "^4.1.18",
        "@tailwindcss/forms": "^0.5.11",
        "package.json": "^2.0.1",
        "preline": "^4.1.1",
        "tailwindcss": "^4.1.18"
    }
}
